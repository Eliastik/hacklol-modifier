{
  "name": "hacklol-modifier",
  "version": "1.4.1-3",
  "description": "",
  "main": "main.js",
  "devDependencies": {
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2",
    "gulp": "^5.0.1",
    "gulp-clean-css": "^4.3.0",
    "gulp-minify": "^3.1.0",
    "gulp-zip": "^6.1.0"
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  },
  "overrides": {
    "gulp-minify": {
      "terser": "^4.8.1"
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "gulp build",
    "start": "electron .",
    "build-static-php-linux": "chmod +x ./build-static-php-linux.sh && ./build-static-php-linux.sh",
    "build-linux": "chmod +x ./build-static-php-linux.sh && chmod +x ./build-electron-linux.sh && ./build-electron-linux.sh",
    "package-linux": "electron-builder --linux",
    "package-windows": "electron-builder --windows"
  },
  "build": {
    "appId": "org.eliastik.hacklolModifier",
    "productName": "hacklol-modifier",
    "directories": {
      "output": "build/electron",
      "buildResources": "resources"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": ".electron",
        "to": ".electron"
      },
      {
        "from": "hacklol-modifier",
        "to": "hacklol-modifier"
      },
      {
        "from": "www",
        "to": "www"
      }
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "portable": {
      "artifactName": "hacklol-modifier.exe"
    },
    "nsis": {
      "artifactName": "hacklol-modifier-setup.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "licenseFile": "LICENSE.txt"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eliastik/hacklol-modifier.git"
  },
  "author": "Eliastik",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/Eliastik/hacklol-modifier/issues"
  },
  "homepage": "https://github.com/Eliastik/hacklol-modifier#readme"
}